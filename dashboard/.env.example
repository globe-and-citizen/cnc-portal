# Node.js memory limit (increase heap size to prevent out of memory errors)
NODE_OPTIONS=--max-old-space-size=4096

# Backend API URL for authentication
NUXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Chain ID for the connected blockchain network (e.g., 1 for Ethereum mainnet, 11155111 for Sepolia testnet, 31337 for local Hardhat)
NUXT_PUBLIC_CHAIN_ID=31337

# Polygon RPC URL
NUXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com

# Etherscan API V2 key — used server-side to read Polygon (chainid=137) USDC
# deposits/withdrawals for Polymarket accounting. Create one at
# https://etherscan.io/apidashboard (a single key works for all chains).
# PRIVATE: never prefix with NUXT_PUBLIC_ — that would leak it into the browser bundle.
NUXT_ETHERSCAN_API_KEY=
