# ─── Network selection ───────────────────────────────────────────────────────
# Set to "hardhat" to index a local Hardhat node. Default: polygon.
# NETWORK=hardhat

# ─── Polygon ─────────────────────────────────────────────────────────────────
PONDER_RPC_URL_137=https://polygon-mainnet.g.alchemy.com/v2/<your-key>

# ─── Hardhat (local) ─────────────────────────────────────────────────────────
# RPC defaults to http://127.0.0.1:8545 — only set if you use a different port.
# PONDER_RPC_URL_HARDHAT=http://127.0.0.1:8545

# Address of OfficerFactoryBeacon deployed on the local Hardhat node.
# This changes every time you restart `npx hardhat node` and redeploy contracts.
# FACTORY_ADDRESS=0x...

# ─── Database ────────────────────────────────────────────────────────────────
# (Optional) Postgres database URL. If not provided, SQLite will be used.
DATABASE_URL=
