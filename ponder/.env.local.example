# ─── Network selection ───────────────────────────────────────────────────────
# Set to "hardhat" to index a local Hardhat node. Default: polygon.
# NETWORK=hardhat

# ─── Polygon ─────────────────────────────────────────────────────────────────
# Primary RPC pool: comma-separated URLs, load-balanced round-robin.
PONDER_RPC_URLS_137=https://polygon-mainnet.g.alchemy.com/v2/<key-a>,https://polygon-mainnet.g.alchemy.com/v2/<key-b>
# Optional backup pool: used only when the whole primary pool fails.
# PONDER_RPC_URLS_137_BACKUP=https://polygon-rpc.com,https://rpc.ankr.com/polygon
# Max requests/second applied to EACH endpoint (default 25).
# PONDER_RPC_MAX_RPS=25
# Legacy single-URL var — still honored as a fallback if PONDER_RPC_URLS_137 is unset.
# PONDER_RPC_URL_137=https://polygon-mainnet.g.alchemy.com/v2/<your-key>
# Required for all networks
# OfficerFactoryBeacon address for the selected NETWORK
# FACTORY_ADDRESS=0x...
# Optional start block override (must be <= discovery events for Officer/teams)
# START_BLOCK=85735312

# Optional static contracts for the selected NETWORK
# FEE_COLLECTOR_ADDRESS=0x...


# ─── Hardhat (local) ─────────────────────────────────────────────────────────
# RPC defaults to http://127.0.0.1:8545 — only set if you use a different port.
# PONDER_RPC_URL_HARDHAT=http://127.0.0.1:8545

# Address of OfficerFactoryBeacon deployed on the local Hardhat node.
# This changes every time you restart `npx hardhat node` and redeploy contracts.
# FACTORY_ADDRESS=0x...

# (Optional) FeeCollector address on the local Hardhat node.
# Set this to index FeePaid events (used to reconstruct bank fee rows).
# FEE_COLLECTOR_ADDRESS=0x...


# ─── Database ────────────────────────────────────────────────────────────────
# (Optional) Postgres database URL. If not provided, SQLite will be used.
DATABASE_URL=
