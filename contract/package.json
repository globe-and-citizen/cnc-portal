{
  "name": "hardhat-project",
  "scripts": {
    "typechain": "npx hardhat typechain",
    "compile": "npx hardhat compile",
    "node": "npx hardhat node",
    "test": "npx hardhat test",
    "coverage": "npx hardhat coverage",
    "lint": "npm run lint:sol && npm run lint:ts",
    "lint:sol": "npx solhint \"contracts/**/*.sol\"",
    "lint:ts": "npx eslint . --ext .ts",
    "format": "npm run format:sol && npm run format:ts",
    "format:sol": "npx prettier --write \"contracts/**/*.sol\"",
    "format:ts": "prettier --write .",
    "format-check": "npm run format-check:sol && npm run format-check:ts",
    "format-check:sol": "npx prettier --check \"contracts/**/*.sol\"",
    "format-check:ts": "npx prettier --check .",
    "moveConstants": "nodemon scripts/moveConstants.ts",
    "mc": "nodemon scripts/moveConstants.ts",
    "update-abi": "ts-node scripts/copy-abi.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.0.5",
    "@typechain/hardhat": "^9.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "hardhat": "^2.22.1",
    "hardhat-abi-exporter": "^2.11.0",
    "prettier": "3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^5.0.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "@openzeppelin/contracts-upgradeable": "5.1.0",
    "@quant-finance/solidity-datetime": "^2.2.0",
    "dotenv": "^16.4.5"
  }
}
