{
  "name": "hardhat-project",
  "type": "module",
  "scripts": {
    "typechain": "npx hardhat typechain",
    "compile": "npx hardhat build",
    "node": "npx hardhat node",
    "deploy": "bash deploy.sh localhost",
    "deploy:mock": "bash deploy.sh localhost mock",
    "deploy:polygon": "bash deploy.sh polygon",
    "bulk-send": "npx hardhat run ./scripts/bulkSendEth.ts --network localhost",
    "test": "npx hardhat test",
    "coverage": "npx hardhat test --coverage",
    "lint": "npm run lint:sol && npm run lint:ts",
    "lint:sol": "npx solhint \"contracts/**/*.sol\"",
    "lint:ts": "npx eslint . --ext .ts",
    "format": "npm run format:sol && npm run format:ts",
    "format:sol": "npx prettier --write \"contracts/**/*.sol\"",
    "format:ts": "prettier --write '**/*.{ts,js,cjs,mjs,md,yml,yaml}'",
    "format-check": "npm run format-check:sol && npm run format-check:ts",
    "format-check:sol": "npx prettier --check \"contracts/**/*.sol\"",
    "format-check:ts": "npx prettier --check '**/*.{ts,js,cjs,mjs,md,yml,yaml}'",
    "moveConstants": "nodemon scripts/moveConstants.ts",
    "mc": "nodemon scripts/moveConstants.ts",
    "freeze": "ts-node scripts/freeze-version.ts",
    "update-abi": "ts-node scripts/copy-abi.ts",
    "validate-upgrade": "npx hardhat run scripts/validate-upgrade.ts",
    "validate-upgrade:polygon": "npx hardhat run scripts/validate-upgrade.ts --network polygon",
    "validate-upgrade:local": "npx hardhat run scripts/validate-upgrade.ts --network localhost"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.7",
    "@openzeppelin/hardhat-upgrades": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "chai": "^6.0.1",
    "ethers": "^6.14.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "hardhat": "^3.11.0",
    "mocha": "^11.7.1",
    "prettier": "3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^5.0.1",
    "solhint-plugin-chainlink-solidity": "npm:@chainlink/solhint-plugin-chainlink-solidity@^1.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "@openzeppelin/contracts-upgradeable": "5.1.0",
    "@quant-finance/solidity-datetime": "^2.2.0",
    "dotenv": "^16.4.5"
  }
}
