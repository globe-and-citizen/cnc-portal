{
  "extends": "solhint:all",
  "plugins": ["chainlink-solidity"],
  "rules": {
    "chainlink-solidity/prefix-storage-variables-with-s-underscore": "error",
    "chainlink-solidity/prefix-immutable-variables-with-i": "error",
    "chainlink-solidity/prefix-internal-functions-with-underscore": "error",
    "chainlink-solidity/prefix-private-functions-with-underscore": "error",
    "chainlink-solidity/all-caps-constant-storage-variables": "error",
    "chainlink-solidity/explicit-imports": "error",
    "chainlink-solidity/no-hardhat-imports": "error",
    "chainlink-solidity/no-require-statements": "error",
    "chainlink-solidity/inherited-constructor-args-not-in-contract-definition": "warn",
    "chainlink-solidity/no-block-single-if-reverts": "error",
    "compiler-version": ["error", "^0.8.24"],
    "avoid-tx-origin": "error",
    "check-send-result": "error",
    "multiple-sends": "error",
    "reentrancy": "error",
    "not-rely-on-block-hash": "error",
    "avoid-suicide": "error",
    "avoid-sha3": "error",
    "avoid-throw": "error",
    "no-complex-fallback": "error",
    "state-visibility": "error",
    "no-unused-vars": "error",
    "explicit-types": "error",
    "func-visibility": ["error", { "ignoreConstructors": true }],
    "code-complexity": ["warn", 7],
    "function-max-lines": ["warn", 75],
    "max-line-length": ["error", 120],
    "ordering": "error",
    "no-empty-blocks": "error",
    "max-states-count": ["warn", 30],
    "reason-string": ["warn", { "minLength": 10 }],
    "private-vars-leading-underscore": "off",
    "var-name-mixedcase": "off",
    "immutable-vars-naming": "off",
    "comprehensive-interface": "off",
    "foundry-test-functions": "off",
    "gas-named-return-values": "off",
    "gas-indexed-events": "off",
    "gas-increment-by-one": "off",
    "gas-calldata-parameters": "off",
    "gas-strict-inequalities": "off",
    "gas-length-in-loops": "off",
    "gas-struct-packing": "off",
    "gas-small-strings": "off",
    "gas-multitoken1155": "off",
    "gas-custom-errors": "off"
  }
}
